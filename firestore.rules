rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()     { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function role()         { return request.auth.token.role; }
    function userTenantId() { return request.auth.token.tenantId; }

    function isSuperAdmin() { return signedIn() && role() == 'superadmin'; }
    function isOwner()      { return signedIn() && role() == 'owner'; }
    function isAttendant()  { return signedIn() && role() == 'attendant'; }

    // ── Platform (superadmin only) ────────────────────────────────────────
    match /_platform/{doc=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Counters (functions only) ─────────────────────────────────────────
    match /_counters/{doc} {
      allow read, write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if signedIn() && (isSuperAdmin() || uid() == userId || isOwner());
      allow write:  if signedIn() && (isSuperAdmin() || uid() == userId);
    }

    // ── Tenants ───────────────────────────────────────────────────────────
    match /tenants/{tid} {
      allow read:   if signedIn() && (isSuperAdmin() || userTenantId() == tid);
      allow list:   if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isOwner() && userTenantId() == tid);
      allow delete: if isSuperAdmin();

      // ── Parking Lots ───────────────────────────────────────────────────
      match /parkingLots/{lotId} {
        allow read:   if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow write:  if signedIn() && (isSuperAdmin() || (isOwner() && userTenantId() == tid));

        match /slots/{slotId} {
          allow read:  if signedIn() && (isSuperAdmin() || userTenantId() == tid);
          allow write: if false;
        }
      }

      // ── Sessions ───────────────────────────────────────────────────────
      match /sessions/{sessionId} {
        allow read:  if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow write: if false;
      }

      // ── Transactions ───────────────────────────────────────────────────
      match /transactions/{txnId} {
        allow read:   if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow create: if signedIn() && isAttendant() && userTenantId() == tid;
        allow update, delete: if false;
      }

      // ── Shifts ─────────────────────────────────────────────────────────
      match /shifts/{shiftId} {
        allow read:   if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow create: if signedIn() && isAttendant() && userTenantId() == tid;
        allow update: if signedIn() && isAttendant() && userTenantId() == tid;
        allow delete: if false;
      }

      // ── Anomalies, Reports, Subscription ──────────────────────────────
      match /anomalies/{docId} {
        allow read:  if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow write: if false;
      }
      match /reports/{docId} {
        allow read:  if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow write: if false;
      }
      match /subscription/{docId} {
        allow read:  if signedIn() && (isSuperAdmin() || userTenantId() == tid);
        allow write: if isSuperAdmin();
      }
    }
  }
}
