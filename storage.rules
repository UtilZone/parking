rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn()    { return request.auth != null; }
    function userRole()    { return request.auth.token.role; }
    function userTenantId(){ return request.auth.token.tenantId; }
    function isSuperAdmin(){ return signedIn() && userRole() == 'superadmin'; }
    function isOwner()     { return signedIn() && userRole() == 'owner'; }
    function isAttendant() { return signedIn() && userRole() == 'attendant'; }
    function isImage()     { return request.resource.contentType.matches('image/.*'); }
    function maxSize(mb)   { return request.resource.size <= mb * 1024 * 1024; }

    // ── Tenant-scoped vehicle entry photos ──────────────────────────────
    match /tenants/{tid}/sessions/{sessionId}/entry.jpg {
      allow read:  if isSuperAdmin() || (signedIn() && userTenantId() == tid);
      allow write: if isAttendant() && userTenantId() == tid && isImage() && maxSize(5);
    }

    // ── Tenant-scoped cash proof photos ──────────────────────────────────
    match /tenants/{tid}/cash-proofs/{txnId} {
      allow read:  if isSuperAdmin()
                   || (isOwner() && userTenantId() == tid)
                   || (isAttendant() && userTenantId() == tid);
      allow write: if isAttendant() && userTenantId() == tid && isImage() && maxSize(5);
    }

    // ── Tenant-scoped generated PDF reports ──────────────────────────────
    match /tenants/{tid}/reports/{fileName} {
      allow read:  if isSuperAdmin() || (isOwner() && userTenantId() == tid);
      allow write: if false;
    }

    // ── User avatars ──────────────────────────────────────────────────────
    match /avatars/{userId} {
      allow read:  if signedIn();
      allow write: if signedIn() && request.auth.uid == userId && isImage() && maxSize(2);
    }

    // ── Platform-level assets ─────────────────────────────────────────────
    match /_platform/{allPaths=**} {
      allow read:  if signedIn();
      allow write: if isSuperAdmin();
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
