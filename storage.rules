rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn()    { return request.auth != null; }
    function role()        { return request.auth.token.role; }
    function tenantId()    { return request.auth.token.tenantId; }
    function isSuperAdmin(){ return signedIn() && role() == 'superadmin'; }
    function isOwner()     { return signedIn() && role() == 'owner'; }
    function isAttendant() { return signedIn() && role() == 'attendant'; }
    function isImage()     { return request.resource.contentType.matches('image/.*'); }
    function maxSize(mb)   { return request.resource.size <= mb * 1024 * 1024; }

    // ── Tenant-scoped vehicle entry photos ──────────────────────────────
    match /tenants/{tenantId}/sessions/{sessionId}/entry.jpg {
      allow read:  if isSuperAdmin() || (signedIn() && tenantId() == tenantId);
      allow write: if isAttendant()  && tenantId() == tenantId && isImage() && maxSize(5);
    }

    // ── Tenant-scoped cash proof photos ──────────────────────────────────
    match /tenants/{tenantId}/cash-proofs/{txnId}.jpg {
      allow read:  if isSuperAdmin() || isOwner() && tenantId() == tenantId
                   || isAttendant()  && tenantId() == tenantId;
      allow write: if isAttendant()  && tenantId() == tenantId && isImage() && maxSize(5);
    }

    // ── Tenant-scoped generated PDF reports ──────────────────────────────
    match /tenants/{tenantId}/reports/{fileName} {
      allow read:  if isSuperAdmin() || (isOwner() && tenantId() == tenantId);
      allow write: if false;   // Cloud Functions only
    }

    // ── User avatars ──────────────────────────────────────────────────────
    match /avatars/{userId}.jpg {
      allow read:  if signedIn();
      allow write: if signedIn() && request.auth.uid == userId && isImage() && maxSize(2);
    }

    // ── Platform-level assets (announcements, branding) ──────────────────
    match /_platform/{allPaths=**} {
      allow read:  if signedIn();
      allow write: if isSuperAdmin();
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
