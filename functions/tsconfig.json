{
  "compilerOptions": {
    "module":            "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals":    false,
    "outDir":            "lib",
    "sourceMap":         true,
    "strict":            false,
    "noImplicitAny":     false,
    "target":            "es2017",
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "skipLibCheck":      true
  },
  "compileOnSave": true,
  "include": ["src"]
}
