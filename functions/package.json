    "firebase-functions": "^5.1.0",
    "pdfkit":             "^0.15.0",
    "typescript":         "^5.4.5"
  },
  "devDependencies": {
    "@types/node":   "^20.0.0",
    "@types/pdfkit": "^0.13.4"
  }
}
